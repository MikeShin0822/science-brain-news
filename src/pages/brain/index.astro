---
import BaseLayout from '../../layouts/BaseLayout.astro';
import NewsCard from '../../components/NewsCard.astro';
import { getNewsByCategory } from '../../utils/news';
const items = await getNewsByCategory('뇌과학');
---
<BaseLayout title="뇌과학 | Science Brain News">
  <section class="container hero">
    <span class="kicker">BRAIN SCIENCE</span>
    <h1>뇌를 이해하는<br />새로운 단서.</h1>
    <p class="lead">인지, 수면, 감정, 기억과 신경가소성 연구를 과장 없이 정리합니다.</p>
  </section>

  <section class="container section">
    <div class="section-head">
      <div>
        <span class="section-label">ARCHIVE</span>
        <h2>뇌과학 글 {items.length}개</h2>
        <p>최신 글부터 시간순으로 모았습니다.</p>
      </div>
    </div>
    <div class="grid">{items.map((item) => <NewsCard item={item} />)}</div>
  </section>
</BaseLayout>
