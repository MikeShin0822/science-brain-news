---
const { item } = Astro.props;
const base = import.meta.env.BASE_URL;
const categoryClass = item.category === '뇌과학' ? 'brain' : item.category === '생명과학' ? 'life' : 'paper';
---
<a class="card" href={`${base}news/${item.slug}/`}>
  <div class="meta">
    <span class={`badge ${categoryClass}`}>{item.category}</span>
    <span>{new Date(item.date).toLocaleDateString('ko-KR')}</span>
    <span>{item.source}</span>
  </div>
  <h3>{item.title}</h3>
  <p>{item.description}</p>
  <div class="tags">
    {item.tags?.map((tag) => <span class="tag">#{tag}</span>)}
  </div>
</a>
