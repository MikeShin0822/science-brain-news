---
const { item } = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const href = (path = '') => `${base}${path.replace(/^\/+/, '')}`;
const categoryClass = item.category === '뇌과학' ? 'brain' : item.category === '생명과학' ? 'life' : 'paper';
const sourceName = item.source?.includes(' / ') ? item.source.split(' / ').at(-1) : item.source;
const visibleTags = item.tags?.slice(0, 2) ?? [];
---
<a class={`card card-${categoryClass}`} href={href(`news/${item.slug}/`)}>
  <div class="card-top">
    <span class={`badge ${categoryClass}`}>{item.category}</span>
    <time datetime={item.date}>{new Date(item.date).toLocaleDateString('ko-KR')}</time>
  </div>

  <h3>{item.title}</h3>
  <p>{item.description}</p>

  <div class="card-tags">
    {visibleTags.map((tag) => <span>#{tag}</span>)}
  </div>

  <div class="card-footer">
    <span class="card-source" title={item.source}>{sourceName}</span>
    <span class="card-arrow" aria-hidden="true">→</span>
  </div>
</a>
