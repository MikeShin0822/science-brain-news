---
import '../styles/global.css';

const {
  title = 'Science Brain News',
  description = '뇌과학과 생명과학에서 핫하거나 유용한 뉴스를 선별해 정리합니다.'
} = Astro.props;
const base = import.meta.env.BASE_URL.endsWith('/') ? import.meta.env.BASE_URL : `${import.meta.env.BASE_URL}/`;
const href = (path = '') => `${base}${path.replace(/^\/+/, '')}`;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" href={href('favicon.svg')} />
    <link rel="alternate" type="application/rss+xml" title="Science Brain News RSS" href={href('rss.xml')} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container nav">
        <a class="logo" href={base}>Science <span>Brain</span> News</a>
        <nav class="nav-links" aria-label="Main navigation">
          <a href={base}>Today</a>
          <a href={href('brain/')}>뇌과학</a>
          <a href={href('life/')}>생명과학</a>
          <a href={href('papers/')}>논문</a>
          <a href={href('about/')}>About</a>
          <a href={href('rss.xml')}>RSS</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="footer">
      <div class="container">
        <p>Science Brain News는 자동 수집 후보를 사람이 다시 읽기 쉽게 큐레이션하는 GitHub Pages 뉴스 아카이브입니다.</p>
      </div>
    </footer>
  </body>
</html>
